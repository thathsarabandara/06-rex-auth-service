MYSQL_DATABASE=rex_auth
MYSQL_USER=rex_user
MYSQL_PASSWORD=rex_password
MYSQL_ROOT_PASSWORD=rex_root_password

FLASK_ENV=production
SECRET_KEY=your_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here
DATABASE_URL=mysql+pymysql://rex_user:rex_password@rex-mysql-server:3306/rex_auth
ACCESS_TOKEN_EXPIRES_MINUTES=10
REFRESH_TOKEN_EXPIRES_DAYS=7
OTP_EXPIRES_MINUTES=5
RESET_TOKEN_EXPIRES_MINUTES=20
JWT_COOKIE_SECURE=false
JWT_COOKIE_SAMESITE=Lax
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,https://rex-47.vercel.app
RATE_LIMIT_ENABLED=true
MAIL_SENDER=your_email@example.com
FRONTEND_BASE_URL=https://rex-47.vercel.app
SMTP_ENABLED=true
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_USE_TLS=true
SMTP_TIMEOUT=10
NOTIFICATION_SERVICE_URL=http://rex-notification-service:9008

